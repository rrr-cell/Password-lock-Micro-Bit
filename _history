eld></block></value><statement name=\"DO\"><block type=\"controls_if\"><comment pinned=\"false\" h=\"80\" w=\"160\">Read column. If it drops to 0, that key is pressed!</comment><value name=\"IF0\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"logic_compare\"><field name=\"OP\">EQ</field><value name=\"A\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"device_get_digital_pin\"><value name=\"name\"><shadow type=\"digital_pin_shadow\"><field name=\"pin\">DigitalPin.P0</field></shadow><block type=\"lists_index_get\"><value name=\"LIST\"><block type=\"variables_get\"><field name=\"VAR\" id=\"_}3)eQP5f/K5,ywwJhX_\">cols</field></block></value><value name=\"INDEX\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"{IVe5X%N:_@u`lvV7@d`\">c</field></block></value></block></value></block></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow></value></block></value><statement name=\"DO0\"><block type=\"function_return\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" no_return_value=\"false\"></mutation><value name=\"RETURN_VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"lists_index_get\"><value name=\"LIST\"><block type=\"lists_index_get\"><value name=\"LIST\"><block type=\"variables_get\"><field name=\"VAR\" id=\"PfgJ^ifoM:y*er3;!AGl\">keys</field></block></value><value name=\"INDEX\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"%#=DY?m7PWilI#@(e-qg\">r</field></block></value></block></value><value name=\"INDEX\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"{IVe5X%N:_@u`lvV7@d`\">c</field></block></value></block></value></block></statement></block></statement></block></next></block></next></block></statement><next><block type=\"function_return\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" no_return_value=\"false\"></mutation><value name=\"RETURN_VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"text\"><field name=\"TEXT\"></field></block></value></block></next></block></statement></block></xml>","main.ts":"// 1. Safe Pin Mapping (Columns stay on P3, P4, P14, P15 with LED matrix disabled)\nlet rows = [DigitalPin.P11, DigitalPin.P8, DigitalPin.P12, DigitalPin.P13]\nlet cols = [DigitalPin.P3, DigitalPin.P4, DigitalPin.P14, DigitalPin.P15]\n\n// 2. PERFECT RE-TRANSPOSED GRID: Corrected layout orientation to match ABCD = 123A\nlet keys = [\n    [\"D\", \"#\", \"0\", \"*\"],\n    [\"C\", \"9\", \"8\", \"7\"],\n    [\"B\", \"6\", \"5\", \"4\"],\n    [\"A\", \"3\", \"2\", \"1\"]\n]\n\nlet userEntered = \"\"\nlet correctCode = \"1234\"\n\n// CRITICAL HARDWARE FIX: Turn off the built-in 5x5 LED matrix to free up pins completely\nled.enable(false)\n\n// 3. Set Pull-Up resistors on column pins\npins.setPull(DigitalPin.P3, PinPullMode.PullUp)\npins.setPull(DigitalPin.P4, PinPullMode.PullUp)\npins.setPull(DigitalPin.P14, PinPullMode.PullUp)\npins.setPull(DigitalPin.P15, PinPullMode.PullUp)\n\n// 4. Initialize your I2C LCD Screen\nI2C_LCD1602.LcdInit(39) // Change 39 to 63 if the screen remains blank\nI2C_LCD1602.BacklightOn()\nI2C_LCD1602.ShowString(\"Enter Code:\", 0, 0)\n\n// 5. Matrix scanning function\nfunction readKeypad(): string {\n    for (let r = 0; r < 4; r++) {\n        // Power all rows HIGH\n        for (let i = 0; i < 4; i++) {\n            pins.digitalWritePin(rows[i], 1)\n        }\n        // Pull the active row being scanned LOW\n        pins.digitalWritePin(rows[r], 0)\n\n        for (let c = 0; c < 4; c++) {\n            // Read column. If it drops to 0, that key is pressed!\n            if (pins.digitalReadPin(cols[c]) == 0) {\n                return keys[r][c]\n            }\n        }\n    }\n    return \"\"\n}\n\n// 6. Main execution loop\nbasic.forever(function () {\n    let myKey = readKeypad()\n\n    if (myKey != \"\") {\n        // Option A: Clear everything if \"#\" is pressed\n        if (myKey == \"#\") {\n            music.playTone(150, music.beat(BeatFraction.Quarter))\n            userEntered = \"\"\n            I2C_LCD1602.clear()\n            I2C_LCD1602.ShowString(\"Enter Code:\", 0, 0)\n        }\n        // Option B: Backspace if \"*\" is pressed\n        else if (myKey == \"*\") {\n            if (userEntered.length > 0) {\n                music.playTone(200, music.beat(BeatFraction.Quarter))\n                I2C_LCD1602.ShowString(\" \", userEntered.length - 1, 1)\n                userEntered = userEntered.substr(0, userEntered.length - 1)\n            }\n        }\n        // Option C: Enter digit and show it on screen\n        else {\n            music.playTone(262, music.beat(BeatFraction.Whole))\n            userEntered = \"\" + userEntered + myKey\n            I2C_LCD1602.ShowString(myKey, userEntered.length - 1, 1)\n\n            // Validate code when 4 characters are reached\n            if (userEntered.length == 4) {\n                basic.pause(500)\n                I2C_LCD1602.clear()\n\n                if (userEntered == correctCode) {\n                    I2C_LCD1602.ShowString(\"ACCESS GRANTED\", 0, 0)\n                    music.playTone(523, music.beat(BeatFraction.Double))\n                } else {\n                    I2C_LCD1602.ShowString(\"ACCESS DENIED\", 0, 0)\n                    music.playTone(131, music.beat(BeatFraction.Double))\n                }\n\n                basic.pause(2000)\n                userEntered = \"\"\n                I2C_LCD1602.clear()\n                I2C_LCD1602.ShowString(\"Enter Code:\", 0, 0)\n            }\n        }\n        basic.pause(300) // Debounce delay\n    }\n})\n","README.md":"","main.py":"def on_forever():\n    keypad.set_key_pad4(DigitalPin.P5,\n        DigitalPin.P6,\n        DigitalPin.P7,