_LCD1602.LcdInit(39)\nI2C_LCD1602.BacklightOn()\nI2C_LCD1602.ShowString(\"Enter Code:\", 0, 0)\n\n// 4. Matrix scanning function\nfunction readKeypad(): string {\n    for (let r = 0; r < 4; r++) {\n        // Power all rows HIGH\n        for (let i = 0; i < 4; i++) {\n            pins.digitalWritePin(rows[i], 1)\n        }\n        // Pull the active row being scanned LOW\n        pins.digitalWritePin(rows[r], 0)\n\n        for (let c = 0; c < 4; c++) {\n            // Read column. If it drops to 0, that key is pressed!\n            if (pins.digitalReadPin(cols[c]) == 0) {\n                return keys[r][c]\n            }\n        }\n    }\n    return \"\"\n}\n\n// 5. Main execution loop\nbasic.forever(function () {\n    let myKey = readKeypad()\n\n    if (myKey != \"\") {\n        // Clear everything if \"#\" is pressed\n        if (myKey == \"#\") {\n            music.playTone(150, music.beat(BeatFraction.Quarter))\n            userEntered = \"\"\n            I2C_LCD1602.clear()\n            I2C_LCD1602.ShowString(\"Enter Code:\", 0, 0)\n        }\n        // Backspace if \"*\" is pressed\n        else if (myKey == \"*\") {\n            if (userEntered.length > 0) {\n                music.playTone(200, music.beat(BeatFraction.Quarter))\n                I2C_LCD1602.ShowString(\" \", userEntered.length - 1, 1)\n                userEntered = userEntered.substr(0, userEntered.length - 1)\n            }\n        }\n        // Enter digit and show it on screen\n        else {\n            music.playTone(262, music.beat(BeatFraction.Whole))\n            userEntered = \"\" + userEntered + myKey\n            I2C_LCD1602.ShowString(myKey, userEntered.length - 1, 1)\n\n            // Validate code when 4 characters are reached\n            if (userEntered.length == 4) {\n                basic.pause(500)\n                I2C_LCD1602.clear()\n\n                if (userEntered == correctCode) {\n                    I2C_LCD1602.ShowString(\"ACCESS GRANTED\", 0, 0)\n                    music.playTone(523, music.beat(BeatFraction.Double))\n                } else {\n                    I2C_LCD1602.ShowString(\"ACCESS DENIED\", 0, 0)\n                    music.playTone(131, music.beat(BeatFraction.Double))\n                }\n\n                basic.pause(2000)\n                userEntered = \"\"\n                I2C_LCD1602.clear()\n                I2C_LCD1602.ShowString(\"Enter Code:\", 0, 0)\n            }\n        }\n        basic.pause(300) // Debounce delay\n    }\n})\n","README.md":"","main.py":"def on_forever():\n    keypad.set_key_pad4(DigitalPin.P5,\n        DigitalPin.P6,\n        DigitalPin.P7,\n        DigitalPin.P9,\n        DigitalPin.P11,\n        DigitalPin.P8,\n        DigitalPin.P12,\n        DigitalPin.P13)\n    I2C_LCD1602.lcd_init(0)\n    I2C_LCD1602.show_string(\"Hello\", 0, 1)\nbasic.forever(on_forever)\n","pxt.json":"{\n    \"name\": \"keypad\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"keypad\": \"github:lioujj/pxt-keypad#febb778e65a5035beadfde2424f02a110d1460c4\",\n        \"i2cLCD1602\": \"github:makecode-extensions/i2clcd1602#v1.5.0\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1782680256931,"editorVersion":"8.0.22","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"uL/,/HWd)$,yKscoXG^^\">r</variable><variable id=\"lylV$TH(sribO?coP8N/\">i</variable><variable id=\"tpHt;J83m{5MW)#]%VPI\">rows</variable><variable id=\"9%{XzNK9U{=Sk!.MWzTP\">c</variable><variable id=\"y]e({w8~{/{*:-?#M,_v\">cols</variable><variable id=\"-FtgMSV?/NspsIYTq^et\">keys</variable><variable id=\"zYNdzQ4q]W]TUV]Z}!eb\">myKey</variable><variable id=\"]EvI/6l!.:^C0{3a/G_E\">userEntered</variable><variable id=\"I?Scv|nXgkEHG9(Q{5eM\">correctCode</va