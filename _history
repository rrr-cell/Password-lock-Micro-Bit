t-on-start\"></block>\n  <block type=\"device_forever\"></block>\n</xml>","main.ts":"\n","README.md":"","pxt.json":"{\n    \"name\": \"keypad\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"additionalFilePaths\": []\n}\n"}},{"timestamp":1782618248093,"editorVersion":"8.0.22","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"device_forever\" x=\"978\" y=\"-97\"><statement name=\"HANDLER\"><block type=\"setKeyPad4\"><field name=\"pin1\">DigitalPin.P5</field><field name=\"pin2\">DigitalPin.P6</field><field name=\"pin3\">DigitalPin.P7</field><field name=\"pin4\">DigitalPin.P9</field><field name=\"pin5\">DigitalPin.P11</field><field name=\"pin6\">DigitalPin.P8</field><field name=\"pin7\">DigitalPin.P12</field><field name=\"pin8\">DigitalPin.P13</field><next><block type=\"I2C_LCD1620_SET_ADDRESS\"><value name=\"addr\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow></value><next><block type=\"I2C_LCD1620_SHOW_STRING\"><value name=\"s\"><shadow type=\"text\"><field name=\"TEXT\">Hello</field></shadow></value><value name=\"x\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"15\" label=\"X\" precision=\"0\"></mutation><field name=\"SLIDER\">0</field></shadow></value><value name=\"y\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"1\" label=\"Y\" precision=\"0\"></mutation><field name=\"SLIDER\">1</field></shadow></value></block></next></block></next></block></statement></block><block type=\"pxt-on-start\" x=\"0\" y=\"0\"></block></xml>","main.ts":"// 1. Define your physical Row and Column pin arrays manually\nlet rows = [DigitalPin.P0, DigitalPin.P1, DigitalPin.P2, DigitalPin.P8]\nlet cols = [DigitalPin.P13, DigitalPin.P14, DigitalPin.P15, DigitalPin.P16]\n\n// 2. Map out the standard layout of a 4x4 keypad matrix\nlet keys = [\n    [\"1\", \"2\", \"3\", \"A\"],\n    [\"4\", \"5\", \"6\", \"B\"],\n    [\"7\", \"8\", \"9\", \"C\"],\n    [\"*\", \"0\", \"#\", \"D\"]\n]\n\nlet userEntered = \"\"\nlet correctCode = \"1234\"\n\n// 3. Initialize your I2C LCD Screen\nI2C_LCD1602.LcdInit(39) // Change 39 to 63 if the screen stays blank\nI2C_LCD1602.BacklightOn()\nI2C_LCD1602.ShowString(\"Enter Code:\", 0, 0)\n\n// 4. Function that scans rows and columns for button presses\nfunction readKeypad(): string {\n    for (let r = 0; r < 4; r++) {\n        // Power all rows HIGH\n        for (let i = 0; i < 4; i++) {\n            pins.digitalWritePin(rows[i], 1)\n        }\n        // Pull the single row being checked LOW\n        pins.digitalWritePin(rows[r], 0)\n\n        for (let c = 0; c < 4; c++) {\n            // Read column. If it dropped to 0, that cross-button was pressed!\n            if (pins.digitalReadPin(cols[c]) == 0) {\n                return keys[r][c]\n            }\n        }\n    }\n    return \"\"\n}\n\n// 5. Main execution loop\nbasic.forever(function () {\n    let myKey = readKeypad()\n\n    if (myKey != \"\") {\n        // OPTION A: Clear everything if \"#\" is pressed\n        if (myKey == \"#\") {\n            music.playTone(150, music.beat(BeatFraction.Quarter))\n            userEntered = \"\"\n            I2C_LCD1602.clear()\n            I2C_LCD1602.ShowString(\"Enter Code:\", 0, 0)\n        }\n        // OPTION B: Backspace if \"*\" is pressed\n        else if (myKey == \"*\") {\n            if (userEntered.length > 0) {\n                music.playTone(200, music.beat(BeatFraction.Quarter))\n                I2C_LCD1602.ShowString(\" \", userEntered.length - 1, 1)\n                userEntered = userEntered.substr(0, userEntered.length - 1)\n            }\n        }\n        // OPTION C: Enter digit\n        else {\n            music.playTone(262, music.beat(BeatFraction.Whole))\n            userEntered = \"\" + userEntered + myKey\n            I2C_LCD1602.ShowString(\"*\", userEntered.length - 1, 1)\n\n            // Validate code when 4 characters are reached\n            if (userEntered.length == 4) {\n                basic.pause(500)\n                I2C_LCD1602.clear()\n\n                if (userEntered == correctCode) {\n                    I2C_LCD1602.ShowString(\"ACCESS GRANTED\", 0, 0)\n                    basic.showIcon(IconNames.Yes)\n                    music.playTone(523, music.beat(BeatFraction.Double))\n                } else {\n                    I2C_LCD1602.ShowString(\"ACCESS DENIED\", 0, 0)\n                    basic.showIcon(IconNames.No)\n                    music.playTone(131, music.beat(BeatFraction.Double))\n                }\n\n                basic.pause(2000)\n                userEntered = \"\"\n                I2C_LCD1602.clear()\n                I2C_LCD1602.ShowString(\"Enter Code:\", 0, 0)\n                basic.clearScreen()\n            }\n        }\n        basic.pause(250) // Debounce delay to avoid registration of duplicate clicks\n    }\n})\n","README.md":"","main.py":"def on_forever():\n    keypad.set_key_pad4(DigitalPin.P5,\n        DigitalPin.P6,\n        DigitalPin.P7,\n        DigitalPin.P9,\n        DigitalPin.P11,\n        DigitalPin.P8,\n        DigitalPin.P12,\n        DigitalPin.P13)\n    I2C_LCD1602.lcd_init(0)\n    I2C_LCD1602.show_string(\"Hello\", 0, 1)\nbasic.forever(on_forever)\n","pxt.json":"{\n    \"name\": \"keypad\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"keypad\": \"github:lioujj/pxt-keypad#febb778e65a5035beadfde2424f02a110d1460c4\",\n        \"i2cLCD1602\": \"github:makecode-extensions/i2clcd1602#v1.5.0\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1782620320465,"editorV