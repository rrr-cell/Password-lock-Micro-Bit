"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"9%{XzNK9U{=Sk!.MWzTP\">c</field></block></value></block></value></block></statement></block></statement></block></next></block></next></block></statement><next><block type=\"function_return\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" no_return_value=\"false\"></mutation><value name=\"RETURN_VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"text\"><field name=\"TEXT\"></field></block></value></block></next></block></statement></block></xml>","main.ts":"// 1. PERFECT PHYSICAL PIN MAPPING (Rows completely flipped to correct the orientation)\nlet rows = [DigitalPin.P11, DigitalPin.P8, DigitalPin.P12, DigitalPin.P13]\nlet cols = [DigitalPin.P5, DigitalPin.P6, DigitalPin.P7, DigitalPin.P9]\n\n// 2. Standard 4x4 horizontal layout map\nlet keys = [\n    [\"1\", \"2\", \"3\", \"A\"],\n    [\"4\", \"5\", \"6\", \"B\"],\n    [\"7\", \"8\", \"9\", \"C\"],\n    [\"*\", \"0\", \"#\", \"D\"]\n]\n\nlet userEntered = \"\"\nlet correctCode = \"1234\"\n\n// 3. Set Pull-Up resistors on column pins\npins.setPull(DigitalPin.P5, PinPullMode.PullUp)\npins.setPull(DigitalPin.P6, PinPullMode.PullUp)\npins.setPull(DigitalPin.P7, PinPullMode.PullUp)\npins.setPull(DigitalPin.P9, PinPullMode.PullUp)\n\n// 4. Initialize your I2C LCD Screen\nI2C_LCD1602.LcdInit(39) // Change 39 to 63 if the screen remains blank\nI2C_LCD1602.BacklightOn()\nI2C_LCD1602.ShowString(\"Enter Code:\", 0, 0)\n\n// 5. Matrix scanning function\nfunction readKeypad(): string {\n    for (let r = 0; r < 4; r++) {\n        // Power all rows HIGH\n        for (let i = 0; i < 4; i++) {\n            pins.digitalWritePin(rows[i], 1)\n        }\n        // Pull the active row being scanned LOW\n        pins.digitalWritePin(rows[r], 0)\n\n        for (let c = 0; c < 4; c++) {\n            // Read column. If it drops to 0, that key is pressed!\n            if (pins.digitalReadPin(cols[c]) == 0) {\n                return keys[r][c]\n            }\n        }\n    }\n    return \"\"\n}\n\n// 6. Main execution loop\nbasic.forever(function () {\n    let myKey = readKeypad()\n\n    if (myKey != \"\") {\n        // Option A: Clear everything if \"#\" is pressed\n        if (myKey == \"#\") {\n            music.playTone(150, music.beat(BeatFraction.Quarter))\n            userEntered = \"\"\n            I2C_LCD1602.clear()\n            I2C_LCD1602.ShowString(\"Enter Code:\", 0, 0)\n        }\n        // Option B: Backspace if \"*\" is pressed\n        else if (myKey == \"*\") {\n            if (userEntered.length > 0) {\n                music.playTone(200, music.beat(BeatFraction.Quarter))\n                I2C_LCD1602.ShowString(\" \", userEntered.length - 1, 1)\n                userEntered = userEntered.substr(0, userEntered.length - 1)\n            }\n        }\n        // Option C: Enter digit and show it on screen\n        else {\n            music.playTone(262, music.beat(BeatFraction.Whole))\n            userEntered = \"\" + userEntered + myKey\n            I2C_LCD1602.ShowString(myKey, userEntered.length - 1, 1)\n\n            // Validate code when 4 characters are reached\n            if (userEntered.length == 4) {\n                basic.pause(500)\n                I2C_LCD1602.clear()\n\n                if (userEntered == correctCode) {\n                    I2C_LCD1602.ShowString(\"ACCESS GRANTED\", 0, 0)\n                    music.playTone(523, music.beat(BeatFraction.Double))\n                } else {\n                    I2C_LCD1602.ShowString(\"ACCESS DENIED\", 0, 0)\n                    music.playTone(131, music.beat(BeatFraction.Double))\n                }\n\n                basic.pause(2000)\n                userEntered = \"\"\n                I2C_LCD1602.clear()\n                I2C_LCD1602.ShowString(\"Enter Code:\", 0, 0)\n            }\n        }\n        basic.pause(300) // Debounce delay\n    }\n})\n","README.md":"",