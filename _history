ode.PullUp)\npins.setPull(DigitalPin.P6, PinPullMode.PullUp)\npins.setPull(DigitalPin.P7, PinPullMode.PullUp)\npins.setPull(DigitalPin.P9, PinPullMode.PullUp)\n\n// 4. Initialize LCD Screen\nI2C_LCD1602.LcdInit(39) // Change to 63 if needed\nI2C_LCD1602.BacklightOn()\nI2C_LCD1602.ShowString(\"Enter Code:\", 0, 0)\n\n// 5. Matrix scanning function\nfunction readKeypad(): string {\n    for (let r = 0; r < 4; r++) {\n        for (let i = 0; i < 4; i++) {\n            pins.digitalWritePin(rows[i], 1)\n        }\n        pins.digitalWritePin(rows[r], 0)\n\n        for (let c = 0; c < 4; c++) {\n            if (pins.digitalReadPin(cols[c]) == 0) {\n                return keys[r][c]\n            }\n        }\n    }\n    return \"\"\n}\n\n// 6. Main processing loop\nbasic.forever(function () {\n    let myKey = readKeypad()\n\n    if (myKey != \"\") {\n        // Pressing \"#\" resets the input line\n        if (myKey == \"#\") {\n            music.playTone(150, music.beat(BeatFraction.Quarter))\n            userEntered = \"\"\n            I2C_LCD1602.clear()\n            I2C_LCD1602.ShowString(\"Enter Code:\", 0, 0)\n        }\n        // Pressing \"*\" acts as a backspace delete\n        else if (myKey == \"*\") {\n            if (userEntered.length > 0) {\n                music.playTone(200, music.beat(BeatFraction.Quarter))\n                I2C_LCD1602.ShowString(\" \", userEntered.length - 1, 1)\n                userEntered = userEntered.substr(0, userEntered.length - 1)\n            }\n        }\n        // Standard digit entries\n        else {\n            music.playTone(262, music.beat(BeatFraction.Whole))\n            userEntered = \"\" + userEntered + myKey\n            I2C_LCD1602.ShowString(myKey, userEntered.length - 1, 1)\n\n            // Check password when length hits 4 digits\n            if (userEntered.length == 4) {\n                basic.pause(500)\n                I2C_LCD1602.clear()\n\n                if (userEntered == correctCode) {\n                    I2C_LCD1602.ShowString(\"ACCESS GRANTED\", 0, 0)\n                    music.playTone(523, music.beat(BeatFraction.Double))\n                } else {\n                    I2C_LCD1602.ShowString(\"ACCESS DENIED\", 0, 0)\n                    music.playTone(131, music.beat(BeatFraction.Double))\n                }\n\n                basic.pause(2000)\n                userEntered = \"\"\n                I2C_LCD1602.clear()\n                I2C_LCD1602.ShowString(\"Enter Code:\", 0, 0)\n            }\n        }\n        basic.pause(300) // Double-click filter delay\n    }\n})\n","README.md":"","main.py":"def on_forever():\n    keypad.set_key_pad4(DigitalPin.P5,\n        DigitalPin.P6,\n        DigitalPin.P7,\n        DigitalPin.P9,\n        DigitalPin.P11,\n        DigitalPin.P8,\n        DigitalPin.P12,\n        DigitalPin.P13)\n    I2C_LCD1602.lcd_init(0)\n    I2C_LCD1602.show_string(\"Hello\", 0, 1)\nbasic.forever(on_forever)\n","pxt.json":"{\n    \"name\": \"keypad\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"keypad\": \"github:lioujj/pxt-keypad#febb778e65a5035beadfde2424f02a110d1460c4\",\n        \"i2cLCD1602\": \"github:makecode-extensions/i2clcd1602#v1.5.0\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1782688085747,"editorVersion":"8.0.22","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"%#=DY?m7PWilI#@(e-qg\">r</variable><variable id=\"ioOL7)7r8j!-?2fr,?[[\">i</variable><variable id=\"~o3.)[g+FuVeqL2oDJ_-\">rows</variable><variable id=\"{IVe5X%N:_@u`lvV7@d`\">c</variable><variable id=\"_}3)eQP5f/K5,ywwJhX_\">cols</variable><variable id=\"PfgJ^ifoM:y*er3;!AGl\">keys</variable><variable id=\"6n0cV!^T?%JYRpx9c1!S\">myKey</variable><variable id=\"DAsWQ?;,dulpesni.,